# Hermes Agent — GCP Configuration
# Copy this to .env and fill in your values. Never commit .env to git.

# ── GCP Core ──────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=hermes-agent-prod
GCP_LOCATION=us-central1
GCP_STAGING_BUCKET=gs://hermes-agent-artifacts

# ── Agent Runtime ─────────────────────────────────────────────────────────────
# Set after first deploy: projects/PROJECT/locations/REGION/reasoningEngines/ID
REASONING_ENGINE_RESOURCE_NAME=

# ── RAG Corpora ───────────────────────────────────────────────────────────────
# Set after creating corpora (scripts/setup_rag.py)
KNOWLEDGE_CORPUS_NAME=
SKILLS_CORPUS_NAME=

# ── Memory Bank (Vertex AI VertexAiMemoryBank) ────────────────────────────────
# Set after running setup_wizard.py — auto-filled from create_memory_bank()
# Format: projects/PROJECT_ID/locations/REGION/memoryBanks/BANK_ID
MEMORY_BANK_RESOURCE_NAME=

# ── API Gateway ───────────────────────────────────────────────────────────────
GATEWAY_PORT=8080
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ── Auth (Firebase / Google OAuth) ────────────────────────────────────────────
# Google OAuth2 audience for validating JWTs from the Web UI
GOOGLE_CLIENT_ID=

# ── Tool Service URLs (set after Cloud Run deploy) ────────────────────────────
BIGQUERY_TOOL_URL=http://localhost:8081
STORAGE_TOOL_URL=http://localhost:8082
SEARCH_TOOL_URL=http://localhost:8083

# ── LLM Models (per agent) ────────────────────────────────────────────────────
# Default: Gemini 2.0 Flash on Vertex AI (no provider prefix needed)
# To use another provider, set "<provider>/<model>" — see docs/cost-estimation.md
#
# PoC cost-optimised preset (uncomment to activate):
# AGENT_MODEL_SKILL_EXTRACTOR=gemini-2.5-flash-lite  # already the default
# AGENT_MODEL_ORCHESTRATOR=gemini-2.5-flash
# AGENT_MODEL_ANALYTICS=gemini-2.5-flash
# AGENT_MODEL_IT_HELPDESK=gemini-2.5-flash
# AGENT_MODEL_HR=gemini-2.5-flash
# AGENT_MODEL_DEVELOPER=gemini-2.5-flash
# AGENT_MODEL_TASK_PLANNER=gemini-2.5-flash
# AGENT_MODEL_TASK_EXECUTOR=gemini-2.5-flash
#
# OpenAI example:
# AGENT_MODEL_ORCHESTRATOR=openai/gpt-4o
# OPENAI_API_KEY=sk-...
#
# Anthropic example:
# AGENT_MODEL_ORCHESTRATOR=anthropic/claude-sonnet-4-5
# ANTHROPIC_API_KEY=sk-ant-...
#
# Azure OpenAI example:
# AGENT_MODEL_ORCHESTRATOR=azure/my-gpt4o-deployment
# AZURE_API_KEY=...
# AZURE_API_BASE=https://my-instance.openai.azure.com/
# AZURE_API_VERSION=2024-02-01
#
# Local Ollama (dev only):
# AGENT_MODEL_ORCHESTRATOR=ollama/llama3

AGENT_MODEL_ORCHESTRATOR=gemini-2.5-flash
AGENT_MODEL_ANALYTICS=gemini-2.5-flash
AGENT_MODEL_IT_HELPDESK=gemini-2.5-flash
AGENT_MODEL_HR=gemini-2.5-flash
AGENT_MODEL_DEVELOPER=gemini-2.5-flash
AGENT_MODEL_TASK_PLANNER=gemini-2.5-flash
AGENT_MODEL_TASK_EXECUTOR=gemini-2.5-flash
AGENT_MODEL_SKILL_EXTRACTOR=gemini-2.5-flash-lite

# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# Only fill in the keys for providers you actually use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=
COHERE_API_KEY=

# ── Firestore ─────────────────────────────────────────────────────────────────
# Firestore collection for task persistence (default: hermes_tasks)
FIRESTORE_TASK_COLLECTION=hermes_tasks

# ── Cloud Scheduler ───────────────────────────────────────────────────────────
# Public Cloud Run URL — fill after first deploy
GATEWAY_URL=https://hermes-gateway-CHANGE_ME.a.run.app
# GCP region for scheduler jobs (match Cloud Run region)
SCHEDULER_LOCATION=us-central1
# Service account that will sign OIDC tokens for scheduler → gateway calls
# Typically: hermes-agent-sa@<PROJECT>.iam.gserviceaccount.com
SCHEDULER_SERVICE_ACCOUNT=hermes-agent-sa@hermes-agent-prod.iam.gserviceaccount.com

# ── Google Workspace ──────────────────────────────────────────────────────────
# Required to enable Gmail, Calendar, and Drive tools.
# Steps:
#   1. Enable domain-wide delegation on your service account in GCP Console.
#   2. In Google Workspace Admin → Security → API Controls → Domain-wide Delegation,
#      add the service account client ID with scopes:
#        https://www.googleapis.com/auth/gmail.readonly
#        https://www.googleapis.com/auth/gmail.send
#        https://www.googleapis.com/auth/calendar
#        https://www.googleapis.com/auth/drive.readonly
#   3. Download the service account JSON key and set WORKSPACE_CREDENTIALS_PATH.
WORKSPACE_DOMAIN=acme.com
WORKSPACE_ADMIN_EMAIL=admin@acme.com
# Path to service account JSON key with domain-wide delegation
WORKSPACE_CREDENTIALS_PATH=/secrets/workspace-sa-key.json

# ── Connectors ────────────────────────────────────────────────────────────────
# Telegram — get token from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=   # any random string; set when calling setWebhook

# Slack — from https://api.slack.com/apps
SLACK_BOT_TOKEN=           # xoxb-...
SLACK_SIGNING_SECRET=

# Microsoft Teams — from Azure Bot registration
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# ── Model Armor ───────────────────────────────────────────────────────────────
# Create a template in GCP Console → Model Armor, then paste the template ID here.
# Leave blank to disable prompt screening (not recommended for production).
MODEL_ARMOR_TEMPLATE_ID=

# ── MCP (Model Context Protocol) ─────────────────────────────────────────────
# Filesystem MCP server: expose a local directory to the developer agent via MCP.
# Requires Node.js / npx installed on the host. Leave blank to disable.
MCP_FILESYSTEM_PATH=
# Remote SSE MCP server URL (optional, for custom tool servers).
MCP_SSE_SERVER_URL=
# Bearer token for the SSE MCP server (optional).
MCP_SSE_AUTH_TOKEN=

# ── Agent Observability (Cloud Trace) ─────────────────────────────────────────
# Set to false to disable Cloud Trace (useful for local dev without GCP creds).
ENABLE_CLOUD_TRACE=true
