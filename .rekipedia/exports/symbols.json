  {
    "name": "HermesMemoryBank",
    "kind": "class",
    "file": "memory/memory_bank.py",
    "line_start": 79,
    "line_end": 406,
    "signature": null,
    "docstring": "Application-level facade over Vertex AI Agent Engine memories.\n\nThe ``resource_name`` is the full AgentEngine resource name, e.g.:\n    projects/my-project/locations/us-central1/reasoningEngines/1234567890\n\nUsage:\n    bank = HermesMemoryBank(resource_name=\"projects/.../reasoningEngines/...\")\n    await bank.generate_memories(user_id=\"u123\", user_text=..., agent_text=...)\n    memories = await bank.fetch_memories(user_id=\"u123\", query=\"VPN setup\")"
  },
