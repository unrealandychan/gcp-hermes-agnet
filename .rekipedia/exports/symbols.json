  {
    "name": "HermesMemoryBank.format_for_prompt",
    "kind": "function",
    "file": "memory/memory_bank.py",
    "line_start": 381,
    "line_end": 406,
    "signature": "format_for_prompt(self, user_id, query, max_tokens)",
    "docstring": "Fetch memories and format them as a system prompt snippet.\n\nReturns an empty string if no memories are found or MemoryBank is unavailable.\nThe caller (gateway/main.py) injects this into the session system prompt."
  },
  {
    "name": "build_memory_bank",
    "kind": "function",
    "file": "memory/memory_bank.py",
    "line_start": 411,
    "line_end": 427,
    "signature": "build_memory_bank()",
    "docstring": "Build a HermesMemoryBank from settings.\n\nReturns None if MEMORY_BANK_RESOURCE_NAME is not configured (graceful degradation)."
  },
  {
    "name": "create_memory_bank",
    "kind": "function",
    "file": "memory/memory_bank.py",
    "line_start": 432,
    "line_end": 470,
    "signature": "create_memory_bank(project, location, display_name)",
    "docstring": "Create a new AgentEngine resource to serve as the MemoryBank.\nReturns the resource name (stored in MEMORY_BANK_RESOURCE_NAME).\n\nSafe to call multiple times — returns existing resource if found.\n\nMigration note:\n    In SDK >= 1.112, there is no standalone VertexAiMemoryBank resource class.\n    Memories are associated with an AgentEngine. This function creates a\n    lightweight AgentEngine (no agent code) dedicated to memory storage,\n    which replaces the old `vertexai.preview.memory_bank.MemoryBank.create()` call."
  },
