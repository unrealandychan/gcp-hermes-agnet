  },
  {
    "name": "HermesMemoryBank.generate_memories",
    "kind": "function",
    "file": "memory/memory_bank.py",
    "line_start": 105,
    "line_end": 141,
    "signature": "generate_memories(self, user_id, user_text, agent_text, agent_name)",
    "docstring": "Distil a conversation turn into durable memories.\n\nCalled from skill_learning_callback (fire-and-forget) after every agent turn.\nThe SDK call is blocking — we wrap it in asyncio.to_thread.\n\nArgs:\n    user_id:    The authenticated user identifier.\n    user_text:  The user's message text.\n    agent_text: The agent's response text.\n    agent_name: Optional agent name for metadata."
  },
  {
    "name": "HermesMemoryBank.ingest_events",
    "kind": "function",
    "file": "memory/memory_bank.py",
    "line_start": 143,
    "line_end": 185,
    "signature": "ingest_events(self, user_id, events)",
    "docstring": "Stream conversation events to Memory Bank for automatic batched memory generation.\n\nMore production-grade than generate_memories() — the SDK batches events\nand triggers memory generation automatically via IngestEvents RPC.\n\nArgs:\n    user_id: The authenticated user identifier.\n    events:  List of event dicts with keys 'role' ('user'|'agent'/'model') and 'text'.\n\nExample:\n    await bank.ingest_events(user_id=\"u1\", events=[\n        {\"role\": \"user\",  \"text\": \"How do I reset my VPN?\"},\n        {\"role\": \"agent\", \"text\": \"Go to Settings > VPN > Reset.\"},\n    ])"
  },
  {
    "name": "HermesMemoryBank.purge_memories",
    "kind": "function",
    "file": "memory/memory_bank.py",
    "line_start": 187,
    "line_end": 225,
    "signature": "purge_memories(self, user_id, dry_run)",
    "docstring": "Bulk-delete all memories for a user.\n\nArgs:\n    user_id: The user whose memories to delete.\n    dry_run: If True, returns count without deleting (default: False).\n\nReturns:\n    Number of memories deleted (or that would be deleted on dry_run)."
  },
  {
    "name": "HermesMemoryBank.delete_memory",
    "kind": "function",
    "file": "memory/memory_bank.py",
    "line_start": 227,
    "line_end": 248,
    "signature": "delete_memory(self, memory_resource_name)",
    "docstring": "Delete a specific memory by its resource name.\n\nArgs:\n    memory_resource_name: Full resource name, e.g.\n        \"projects/p/locations/l/reasoningEngines/e/memories/m\"\n\nReturns:\n    True on success, False on failure."
  },
  {
    "name": "HermesMemoryBank.create_memory",
    "kind": "function",
    "file": "memory/memory_bank.py",
    "line_start": 250,
    "line_end": 283,
    "signature": "create_memory(self, user_id, fact)",
    "docstring": "Directly write a memory fact without LLM extraction/consolidation.\n\nUseful for the 'memory-as-a-tool' pattern where the agent explicitly\ndecides what to remember, bypassing automatic extraction.\n\nArgs:\n    user_id: The user this memory belongs to.\n    fact:    The plain-text fact to store.\n\nReturns:\n    The new memory's resource name, or None on failure."
  },
  {
    "name": "HermesMemoryBank.update_memory",
    "kind": "function",
    "file": "memory/memory_bank.py",
    "line_start": 285,
    "line_end": 313,
    "signature": "update_memory(self, memory_resource_name, new_fact)",
    "docstring": "Update an existing memory with a corrected fact.\n\nArgs:\n    memory_resource_name: Full resource name of the memory to update.\n    new_fact: The corrected/updated fact text.\n\nReturns:\n    True on success, False on failure."
  },
  {
    "name": "HermesMemoryBank.retrieve_profiles",
    "kind": "function",
    "file": "memory/memory_bank.py",
    "line_start": 315,
    "line_end": 329,
    "signature": "retrieve_profiles(self, user_id)",
    "docstring": "Retrieve structured memory profiles for a user.\n\nNote: RetrieveProfiles is not available in the AgentEngine memories API (SDK >= 1.112).\nUse fetch_memories() instead for retrieving relevant context.\n\nReturns:\n    Empty list (not supported in current SDK version)."
  },
  {
    "name": "HermesMemoryBank.fetch_memories",
    "kind": "function",
    "file": "memory/memory_bank.py",
    "line_start": 331,
    "line_end": 367,
    "signature": "fetch_memories(self, user_id, query, top_k)",
    "docstring": "Retrieve the most relevant memories for a user.\n\nCalled at session start (PreloadMemoryTool) to inject user context\ninto the system prompt.\n\nReturns:\n    List of memory strings, ready for system prompt injection."
  },
  {
    "name": "HermesMemoryBank.list_revisions",
    "kind": "function",
    "file": "memory/memory_bank.py",
    "line_start": 369,
